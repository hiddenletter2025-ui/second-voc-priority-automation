# ============================================================
#  VoC Risk Sentinel — .gitignore
# ============================================================

# ── 보안: 절대 업로드 금지 ──────────────────────────────────
.env
.env.local
.env.production
secrets.toml
**/secrets.toml

# .env.example은 업로드 허용 (API Key 설정 가이드용)
!.env.example

# ── Python 런타임 ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python

# ── 가상환경 ─────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.virtualenv/

# ── 파이프라인 런타임 생성물 ──────────────────────────────────
# 체크포인트 (재실행 시 자동 생성됨)
src/checkpoints/
checkpoints/

# 분석 결과 JSONL — GitHub 포함 (대시보드 즉시 시연용)
# src/voc_results.jsonl  ← 포함으로 변경
# voc_results.jsonl      ← 포함으로 변경

# 파이프라인 로그
src/pipeline.log
pipeline.log
*.log

# 기존 분석 결과 CSV (분석 후 생성물)
src/voc_analysis_results.csv
voc_analysis_results.csv

# ── 전체 데이터셋 (샘플만 포함, 전체는 제외) ──────────────────
# 전체 4,000건 데이터는 generate_data.py로 재생성 가능
src/voc_data_4000.csv
outputs/voc_data_4000.csv

# ── Streamlit 설정 캐시 ───────────────────────────────────────
.streamlit/secrets.toml

# ── 개발 도구 ────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── 배포 / 패키징 ────────────────────────────────────────────
dist/
build/
*.egg-info/
.eggs/

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── pytest / coverage ────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
